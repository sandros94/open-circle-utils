{
  "name": "valibot-ast",
  "version": "0.0.0",
  "description": "AST (Abstract Syntax Tree) utilities for Valibot schemas - serialization and reconstruction",
  "license": "MIT",
  "author": {
    "name": "Sandro Circi",
    "email": "sandro.circi@digitoolmedia.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sandros94/open-circle-utils.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "types": "./dist/index.d.mts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./utils": {
      "types": "./dist/utils/index.d.mts",
      "default": "./dist/utils/index.mjs"
    }
  },
  "scripts": {
    "build": "obuild",
    "dev": "obuild --watch",
    "dev:prepare": "obuild --stub",
    "prepack": "pnpm build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsgo --noEmit"
  },
  "devDependencies": {
    "valibot": "^1.2.0"
  },
  "peerDependencies": {
    "valibot": "^1.2.0"
  }
}
