{
  "name": "formisch-utils",
  "version": "0.0.3",
  "description": "Utility functions for working with Formisch forms and Valibot schemas",
  "license": "MIT",
  "author": {
    "name": "Sandro Circi",
    "email": "sandro.circi@digitoolmedia.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sandros94/open-circle-utils.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "types": "./dist/index.d.mts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./preact": {
      "types": "./dist/preact/index.d.mts",
      "default": "./dist/preact/index.mjs"
    },
    "./qwik": {
      "types": "./dist/qwik/index.d.mts",
      "default": "./dist/qwik/index.mjs"
    },
    "./react": {
      "types": "./dist/react/index.d.mts",
      "default": "./dist/react/index.mjs"
    },
    "./solid": {
      "types": "./dist/solid/index.d.mts",
      "default": "./dist/solid/index.mjs"
    },
    "./vue": {
      "types": "./dist/vue/index.d.mts",
      "default": "./dist/vue/index.mjs"
    }
  },
  "scripts": {
    "build": "obuild",
    "dev": "obuild --watch",
    "dev:prepare": "obuild --stub",
    "prepack": "pnpm build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "valibot-ast": "^0.0.2"
  },
  "devDependencies": {
    "@qwik.dev/core": "^2.0.0-beta.24",
    "preact": "^10.28.4",
    "react": "^19.2.4",
    "valibot": "^1.2.0"
  },
  "peerDependencies": {
    "@formisch/preact": "^0.9.2",
    "@formisch/qwik": "^0.9.3",
    "@formisch/react": "^0.4.2",
    "@formisch/solid": "^0.9.2",
    "@formisch/svelte": "^0.7.2",
    "@formisch/vue": "^0.7.2",
    "preact": "^10.0.0",
    "react": "^16.0.0 || ^17.0.0 || ^18.0.0 || ^19.0.0",
    "valibot": "^1.2.0"
  },
  "peerDependenciesMeta": {
    "@formisch/preact": {
      "optional": true
    },
    "@formisch/qwik": {
      "optional": true
    },
    "@formisch/react": {
      "optional": true
    },
    "@formisch/solid": {
      "optional": true
    },
    "@formisch/svelte": {
      "optional": true
    },
    "@formisch/vue": {
      "optional": true
    },
    "preact": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  }
}
