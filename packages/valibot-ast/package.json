{
  "name": "valibot-ast",
  "version": "0.0.0",
  "description": "AST (Abstract Syntax Tree) utilities for Valibot schemas - serialization and reconstruction",
  "repository": "sandros94/open-circle-utils",
  "license": "MIT",
  "sideEffects": false,
  "type": "module",
  "author": {
    "name": "Sandro Circi",
    "email": "sandro.circi@digitoolmedia.com"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./types": {
      "types": "./dist/types.d.mts",
      "default": "./dist/types.mjs"
    }
  },
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "obuild",
    "dev": "obuild --watch",
    "dev:prepare": "obuild --stub",
    "prepack": "pnpm build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "valibot-introspection": "workspace:*"
  },
  "peerDependencies": {
    "valibot": "^1.2.0"
  },
  "devDependencies": {
    "valibot": "^1.2.0"
  }
}
