{
  "name": "formisch-utils",
  "version": "0.0.0",
  "description": "Utility functions for working with Formisch forms and Valibot schemas",
  "repository": "sandros94/open-circle-utils",
  "license": "MIT",
  "sideEffects": false,
  "type": "module",
  "author": {
    "name": "Sandro Circi",
    "email": "sandro.circi@digitoolmedia.com"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "obuild",
    "dev": "obuild --watch",
    "dev:prepare": "obuild --stub",
    "prepack": "pnpm build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "valibot-ast": "workspace:*"
  },
  "peerDependencies": {
    "valibot": "^1.2.0"
  },
  "devDependencies": {
    "valibot": "^1.2.0"
  }
