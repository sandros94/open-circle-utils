{
  "name": "open-circle-utils",
  "version": "0.0.0",
  "description": "Monorepo for validation library utilities",
  "license": "MIT",
  "author": {
    "name": "Sandro Circi",
    "email": "sandro.circi@digitoolmedia.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sandros94/open-circle-utils.git"
  },
  "type": "module",
  "scripts": {
    "build": "pnpm -r --parallel build",
    "dev": "pnpm -r --parallel dev",
    "dev:prepare": "pnpm -r --parallel dev:prepare",
    "lint": "oxlint . && oxfmt --check .",
    "format": "automd && oxlint --fix . && oxfmt .",
    "release:valibot-ast": "node scripts/release.mjs valibot-ast",
    "release:formisch-utils": "node scripts/release.mjs formisch-utils",
    "test": "pnpm -r test",
    "test:coverage": "pnpm -r test:coverage",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@types/react": "^19.2.14",
    "@typescript/native-preview": "7.0.0-dev.20260225.1",
    "@vitest/coverage-v8": "^4.0.18",
    "automd": "^0.4.3",
    "changelogen": "^0.6.2",
    "obuild": "^0.4.31",
    "oxfmt": "^0.33.0",
    "oxlint": "^1.48.0",
    "typescript": "^5.9.3",
    "valibot": "^1.2.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": "22"
  },
  "packageManager": "pnpm@10.30.2"
}
